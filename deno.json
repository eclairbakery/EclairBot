{
    "compilerOptions": {
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "lib": [
            "es2024",
            "deno.ns", "deno.window",
            "dom"
        ]
    },
    "fmt": {
        "indentWidth": 4,
        "useTabs": false,
        "lineWidth": 500,
        "semiColons": true,
        "singleQuote": true
    },
    "lint": {
        "rules": {
            "exclude": [
                "no-namespace",
                "no-empty",
                "require-await"
            ]
        }
    },
    "imports": {
        "discord.js": "npm:discord.js@^14.26.3",
        "dotenv": "npm:dotenv@^17.4.2",
        "figlet": "npm:figlet@^1.11.0",
        "imapflow": "npm:imapflow@^1.3.2",
        "json5": "npm:json5@^2.2.3",
        "mailparser": "npm:mailparser@^3.9.8",
        "nodemailer": "npm:nodemailer@^8.0.6",
        "gemini": "npm:@google/generative-ai@^0.24.1",
        "sqlite": "https://deno.land/x/sqlite@v3.9.1/mod.ts",
        "@/": "./src/"
    }
}
